        "import json\n",
        "import ipywidgets as widgets\n",
        "from IPython.display import display, HTML, clear_output\n",
        "\n",
        "# ============================================================\n",
        "# NETWORK_CONFIG — defaults. The GUI below will overwrite this.\n",
        "# ============================================================\n",
        "NETWORK_CONFIG = {\n",
        "    \"encoder_layers\": [\n",
        "        {\"out_channels\": 32,  \"resblock\": False},\n",
        "        {\"out_channels\": 64,  \"resblock\": True},\n",
        "        {\"out_channels\": 128, \"resblock\": True},\n",
        "        {\"out_channels\": 256, \"resblock\": True},\n",
        "        {\"out_channels\": 512, \"resblock\": True},\n",
        "    ],\n",
        "    \"latent_dim\": 256,\n",
        "    \"decoder_channels\": [256, 128, 64, 32, 16],\n",
        "}\n",
        "\n",
        "# --- Layer UI state ---\n",
        "_layer_widgets = []  # list of {\"channels\": Dropdown, \"resblock\": Checkbox}\n",
        "_layers_box = widgets.VBox()\n",
        "_status_out = widgets.Output()\n",
        "\n",
        "_CHANNEL_OPTIONS = [4, 8, 16, 32, 64, 128, 256, 512, 1024]\n",
        "\n",
        "def _make_layer_row(idx, out_ch=64, resblock=True):\n",
        "    ch_drop = widgets.Dropdown(\n",
        "        options=_CHANNEL_OPTIONS, value=out_ch,\n",
        "        description=f'Layer {idx+1}:', layout=widgets.Layout(width='180px'),\n",
        "        style={'description_width': '60px'}\n",
        "    )\n",
        "    rb_check = widgets.Checkbox(value=resblock, description='ResBlock',\n",
        "                                 indent=False, layout=widgets.Layout(width='100px'))\n",
        "    ch_drop.observe(lambda _: _refresh_summary(), names='value')\n",
        "    rb_check.observe(lambda _: _refresh_summary(), names='value')\n",
        "    return {\"channels\": ch_drop, \"resblock\": rb_check}\n",
        "\n",
        "def _render_layers():\n",
        "    rows = []\n",
        "    for i, lw in enumerate(_layer_widgets):\n",
        "        lw[\"channels\"].description = f'Layer {i+1}:'\n",
        "        rows.append(widgets.HBox([lw[\"channels\"], lw[\"resblock\"]]))\n",
        "    _layers_box.children = rows\n",
        "    _refresh_summary()\n",
        "\n",
        "def _add_layer(_=None):\n",
        "    prev = _layer_widgets[-1][\"channels\"].value if _layer_widgets else 64\n",
        "    new_ch = min(prev * 2, 1024)\n",
        "    if new_ch not in _CHANNEL_OPTIONS:\n",
        "        new_ch = min(_CHANNEL_OPTIONS, key=lambda x: abs(x - new_ch))\n",
        "    _layer_widgets.append(_make_layer_row(len(_layer_widgets), new_ch, True))\n",
        "    _render_layers()\n",
        "\n",
        "def _remove_layer(_=None):\n",
        "    if len(_layer_widgets) > 1:\n",
        "        _layer_widgets.pop()\n",
        "        _render_layers()\n",
        "\n",
        "def _apply_config(_=None):\n",
        "    global NETWORK_CONFIG\n",
        "    enc_layers = []\n",
        "    for lw in _layer_widgets:\n",
        "        enc_layers.append({\n",
        "            \"out_channels\": lw[\"channels\"].value,\n",
        "            \"resblock\": lw[\"resblock\"].value,\n",
        "        })\n",
        "    latent = _latent_slider.value\n",
        "    # Auto-generate decoder channels\n",
        "    bot = enc_layers[-1][\"out_channels\"]\n",
        "    dec = []\n",
        "    ch = bot\n",
        "    for _ in range(5):\n",
        "        dec.append(ch)\n",
        "        ch = max(ch // 2, 16)\n",
        "    NETWORK_CONFIG = {\n",
        "        \"encoder_layers\": enc_layers,\n",
        "        \"latent_dim\": latent,\n",
        "        \"decoder_channels\": dec,\n",
        "    }\n",
        "    with _status_out:\n",
        "        _status_out.clear_output()\n",
        "        print(f\"\\u2713 NETWORK_CONFIG updated!\")\n",
        "        print(f\"  Encoder: {len(enc_layers)} layers \\u2192 {enc_layers[-1]['out_channels']}-dim bottleneck\")\n",
        "        print(f\"  Latent dim: {latent}\")\n",
        "        print(f\"  Decoder stages: {dec}\")\n",
        "        print(f\"  \\u2192 Now re-run Model Definition (cell 14) + Training Setup (cell 18).\")\n",
        "\n",
        "def _refresh_summary(_=None):\n",
        "    layers_str = \" \\u2192 \".join(\n",
        "        f\"{lw['channels'].value}\" + (\" +R\" if lw['resblock'].value else \"\")\n",
        "        for lw in _layer_widgets\n",
        "    )\n",
        "    _summary_label.value = f\"<b style='color:#5ec4d4'>7ch input \\u2192 {layers_str} \\u2192 pool \\u2192 latent({_latent_slider.value})</b>\"\n",
        "\n",
        "# --- Build widgets ---\n",
        "_latent_slider = widgets.IntSlider(value=NETWORK_CONFIG[\"latent_dim\"], min=8, max=1024, step=8,\n",
        "                                    description='Latent dim:', style={'description_width': '80px'},\n",
        "                                    layout=widgets.Layout(width='350px'))\n",
        "_latent_slider.observe(lambda _: _refresh_summary(), names='value')\n",
        "\n",
        "_add_btn = widgets.Button(description='+ Layer', button_style='info', icon='plus',\n",
        "                           layout=widgets.Layout(width='100px'))\n",
        "_remove_btn = widgets.Button(description='- Layer', button_style='warning', icon='minus',\n",
        "                              layout=widgets.Layout(width='100px'))\n",
        "_apply_btn = widgets.Button(description='\\u25b6 Apply to Model', button_style='success', icon='check',\n",
        "                             layout=widgets.Layout(width='200px', height='36px'))\n",
        "\n",
        "_add_btn.on_click(_add_layer)\n",
        "_remove_btn.on_click(_remove_layer)\n",
        "_apply_btn.on_click(_apply_config)\n",
        "\n",
        "_summary_label = widgets.HTML()\n",
        "\n",
        "# Initialize layers from current config\n",
        "for i, layer_cfg in enumerate(NETWORK_CONFIG[\"encoder_layers\"]):\n",
        "    ch = layer_cfg[\"out_channels\"]\n",
        "    if ch not in _CHANNEL_OPTIONS:\n",
        "        ch = min(_CHANNEL_OPTIONS, key=lambda x: abs(x - ch))\n",
        "    _layer_widgets.append(_make_layer_row(i, ch, layer_cfg.get(\"resblock\", False)))\n",
        "_render_layers()\n",
        "\n",
        "# --- PBR output info (read-only display) ---\n",
        "_pbr_info_rows = []\n",
        "for name, cfg in pbr_config.items():\n",
        "    if cfg[\"enabled\"]:\n",
        "        t = cfg[\"type\"].replace(\"_\", \" \").title()\n",
        "        _pbr_info_rows.append(f\"<span style='color:#c0d0e0'>{name}</span> <span style='color:#5ec4d4;font-size:11px'>({t}, {cfg['channels']}ch)</span>\")\n",
        "_pbr_html = widgets.HTML(\n",
        "    value=\"<div style='background:#1a2332;padding:12px;border-radius:8px;font-family:monospace;font-size:12px'>\"\n",
        "          \"<div style='color:#5ec4d4;font-weight:600;margin-bottom:6px'>ENABLED PBR OUTPUTS:</div>\"\n",
        "          + \"<br>\".join(_pbr_info_rows) + \"</div>\"\n",
        ")\n",
        "\n",
        "# --- Layout ---\n",
        "_title_html = widgets.HTML(\n",
        "    value=\"<div style='background:#1a2332;padding:16px 20px;border-radius:10px 10px 0 0;border-bottom:1px solid #2a3a4e'>\"\n",
        "          \"<h2 style='color:#5ec4d4;margin:0;font-size:18px'>PBR Neural Network Architecture</h2>\"\n",
        "          \"<div style='color:#7a8fa3;font-size:12px;margin-top:4px'>Configure encoder layers, then click Apply to Model</div></div>\"\n",
        ")\n",
        "\n",
        "_gui = widgets.VBox([\n",
        "    _title_html,\n",
        "    widgets.HBox([_add_btn, _remove_btn, _latent_slider],\n",
        "                 layout=widgets.Layout(padding='8px', gap='10px')),\n",
        "    _layers_box,\n",
        "    _summary_label,\n",
        "    widgets.HBox([_apply_btn], layout=widgets.Layout(justify_content='center', padding='12px 0')),\n",
        "    widgets.HBox([_pbr_html], layout=widgets.Layout(padding='0 0 8px 0')),\n",
        "    _status_out,\n",
        "], layout=widgets.Layout(border='1px solid #2a3a4e', border_radius='10px', padding='0'))\n",
        "\n",
        "display(_gui)\n",
        "\n",
        "print(f\"Current: {len(NETWORK_CONFIG['encoder_layers'])} encoder layers, \"\n",
        "      f\"latent_dim={NETWORK_CONFIG['latent_dim']}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 51,
      "metadata": {
        "id": "d7BxkEQICdkZ"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "PBRNet output shapes (from NETWORK_CONFIG):\n",
            "  base_color: torch.Size([2, 3, 128, 128])\n",
            "  metallic: torch.Size([2, 1, 128, 128])\n",
            "  roughness: torch.Size([2, 1, 128, 128])\n",
            "  specular: torch.Size([2, 3, 128, 128])\n",
            "  normal_map: torch.Size([2, 3, 128, 128])\n",
            "  ao: torch.Size([2, 1, 128, 128])\n",
