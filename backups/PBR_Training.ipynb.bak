          "text": [
            "Epoch  1/20 | Total: 0.6690 | Render: 0.2485 | Supervised: 0.2101 | TV: 0.0321 | LR: 4.97e-04\n",
            "Epoch  2/20 | Total: 0.5970 | Render: 0.2455 | Supervised: 0.1756 | TV: 0.0187 | LR: 4.88e-04\n",
            "Epoch  3/20 | Total: 0.5897 | Render: 0.2441 | Supervised: 0.1727 | TV: 0.0160 | LR: 4.73e-04\n",
            "Epoch  4/20 | Total: 0.5853 | Render: 0.2433 | Supervised: 0.1709 | TV: 0.0143 | LR: 4.52e-04\n",
            "Epoch  5/20 | Total: 0.5802 | Render: 0.2435 | Supervised: 0.1683 | TV: 0.0129 | LR: 4.27e-04\n",
            "Epoch  6/20 | Total: 0.5760 | Render: 0.2433 | Supervised: 0.1663 | TV: 0.0124 | LR: 3.97e-04\n",
            "Epoch  7/20 | Total: 0.5713 | Render: 0.2433 | Supervised: 0.1639 | TV: 0.0138 | LR: 3.64e-04\n",
            "Epoch  8/20 | Total: 0.5636 | Render: 0.2417 | Supervised: 0.1609 | TV: 0.0130 | LR: 3.28e-04\n",
            "Epoch  9/20 | Total: 0.5554 | Render: 0.2417 | Supervised: 0.1568 | TV: 0.0145 | LR: 2.90e-04\n",
            "Epoch 10/20 | Total: 0.5404 | Render: 0.2403 | Supervised: 0.1500 | TV: 0.0141 | LR: 2.51e-04\n",
            "Epoch 11/20 | Total: 0.5291 | Render: 0.2381 | Supervised: 0.1454 | TV: 0.0141 | LR: 2.11e-04\n",
            "Epoch 12/20 | Total: 0.5310 | Render: 0.2375 | Supervised: 0.1467 | TV: 0.0137 | LR: 1.73e-04\n",
            "Epoch 13/20 | Total: 0.5267 | Render: 0.2366 | Supervised: 0.1450 | TV: 0.0137 | LR: 1.37e-04\n",
            "Epoch 14/20 | Total: 0.5194 | Render: 0.2352 | Supervised: 0.1421 | TV: 0.0132 | LR: 1.04e-04\n",
            "Epoch 15/20 | Total: 0.5177 | Render: 0.2347 | Supervised: 0.1414 | TV: 0.0131 | LR: 7.41e-05\n",
            "Epoch 16/20 | Total: 0.5160 | Render: 0.2347 | Supervised: 0.1406 | TV: 0.0127 | LR: 4.87e-05\n",
            "Epoch 17/20 | Total: 0.5166 | Render: 0.2340 | Supervised: 0.1412 | TV: 0.0126 | LR: 2.82e-05\n",
            "Epoch 18/20 | Total: 0.5137 | Render: 0.2341 | Supervised: 0.1397 | TV: 0.0127 | LR: 1.32e-05\n",
            "Epoch 19/20 | Total: 0.5120 | Render: 0.2336 | Supervised: 0.1391 | TV: 0.0125 | LR: 4.07e-06\n",
            "Epoch 20/20 | Total: 0.5139 | Render: 0.2335 | Supervised: 0.1401 | TV: 0.0125 | LR: 1.00e-06\n"
          ]
        },
        {
          "data": {
            "image/png": "",
            "text/plain": [
              "<Figure size 1500x400 with 3 Axes>"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ],
      "source": [
        "NUM_EPOCHS = 20\n",
        "RENDER_LOSS_WEIGHT = 1.0\n",
        "SUPERVISED_LOSS_WEIGHT = 2.0\n",
        "TV_LOSS_WEIGHT = 0.01\n",
        "\n",
        "history = {\"total\": [], \"render\": [], \"supervised\": [], \"tv\": []}\n",
        "\n",
        "for epoch in range(NUM_EPOCHS):\n",
        "    model.train()\n",
        "    epoch_losses = {\"total\": 0, \"render\": 0, \"supervised\": 0, \"tv\": 0}\n",
        "    n_batches = 0\n",
        "\n",
        "    for batch in loader:\n",
        "        batch = batch.to(device)  # [B, 7, 128, 128]\n",
        "\n",
        "        # Forward pass\n",
        "        pbr_outputs = model(batch)\n",
        "\n",
        "        # --- 1. Rendering loss ---\n",
        "        rendered = render_pbr_sphere(pbr_outputs, size=128)  # [B, 3, H, W]\n",
        "\n",
        "        # Compare rendered sphere to input RGB channels (resized to sphere)\n",
        "        target_rgb = batch[:, :3, :, :]\n",
        "        target_resized = F.interpolate(target_rgb, size=(128, 128), mode='bilinear', align_corners=False)\n",
        "        render_loss = mse_loss(rendered, target_resized)\n",
        "\n",
        "        # --- 2. Supervised loss on available GT channels ---\n",
        "        sup_loss = torch.tensor(0.0, device=device)\n",
        "\n",
        "        # Dataset has 7 channels: assume RGB(0:3), Normal(3:6), Extra(6)\n",
        "        # Map available GT channels to predicted maps\n",
        "        if \"base_color\" in pbr_outputs and pbr_outputs[\"base_color\"].dim() == 4:\n",
        "            gt_rgb = batch[:, :3, :, :]\n",
        "            pred_rgb = F.interpolate(pbr_outputs[\"base_color\"], size=gt_rgb.shape[2:],\n",
        "                                     mode='bilinear', align_corners=False)\n",
        "            sup_loss = sup_loss + mse_loss(pred_rgb, gt_rgb)\n",
        "\n",
        "        if \"normal_map\" in pbr_outputs and pbr_outputs[\"normal_map\"].dim() == 4:\n",
        "            gt_normal = batch[:, 3:6, :, :]\n",
        "            pred_normal = F.interpolate(pbr_outputs[\"normal_map\"], size=gt_normal.shape[2:],\n",
        "                                        mode='bilinear', align_corners=False)\n",
        "            sup_loss = sup_loss + mse_loss(pred_normal, gt_normal)\n",
        "\n",
        "        # --- 3. TV loss for texture smoothness ---\n",
        "        tv_loss = torch.tensor(0.0, device=device)\n",
        "        for name, out in pbr_outputs.items():\n",
        "            if out.dim() == 4:\n",
        "                tv_loss = tv_loss + total_variation_loss(out)\n",
        "\n",
        "        # --- Total loss ---\n",
        "        loss = (RENDER_LOSS_WEIGHT * render_loss +\n",
        "                SUPERVISED_LOSS_WEIGHT * sup_loss +\n",
        "                TV_LOSS_WEIGHT * tv_loss)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "        loss.backward()\n",
        "        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
        "        optimizer.step()\n",
        "\n",
        "        epoch_losses[\"total\"] += loss.item()\n",
        "        epoch_losses[\"render\"] += render_loss.item()\n",
        "        epoch_losses[\"supervised\"] += sup_loss.item()\n",
        "        epoch_losses[\"tv\"] += tv_loss.item()\n",
        "        n_batches += 1\n",
        "\n",
        "    scheduler.step()\n",
        "\n",
        "    for k in epoch_losses:\n",
        "        epoch_losses[k] /= max(n_batches, 1)\n",
        "        history[k].append(epoch_losses[k])\n",
        "\n",
        "    lr = optimizer.param_groups[0]['lr']\n",
        "    print(f\"Epoch {epoch+1:2d}/{NUM_EPOCHS} | \"\n",
        "          f\"Total: {epoch_losses['total']:.4f} | \"\n",
        "          f\"Render: {epoch_losses['render']:.4f} | \"\n",
        "          f\"Supervised: {epoch_losses['supervised']:.4f} | \"\n",
        "          f\"TV: {epoch_losses['tv']:.4f} | \"\n",
        "          f\"LR: {lr:.2e}\")\n",
        "\n",
        "# Plot training curves\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
        "for ax, key in zip(axes, [\"total\", \"render\", \"supervised\"]):\n",
        "    ax.plot(history[key], linewidth=2)\n",
        "    ax.set_title(f\"{key.capitalize()} Loss\")\n",
        "    ax.set_xlabel(\"Epoch\")\n",
        "    ax.set_ylabel(\"Loss\")\n",
        "    ax.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
