        "model.eval()\n",
        "\n",
        "with torch.no_grad():\n",
        "    sample = next(iter(loader)).to(device)\n",
        "    pbr_out = model(sample)\n",
        "    rendered = render_pbr_sphere(pbr_out, size=128)\n",
        "\n",
        "# Collect texture maps for display\n",
        "tex_maps = {k: v for k, v in pbr_out.items() if v.dim() == 4}\n",
        "scalar_vals = {k: v for k, v in pbr_out.items() if v.dim() == 2}\n",
        "\n",
        "# Print scalar PBR values\n",
        "if scalar_vals:\n",
        "    print(\"Predicted Scalar PBR Parameters (sample 0):\")\n",
        "    for name, val in scalar_vals.items():\n",
        "        print(f\"  {name}: {val[0].item():.4f}\")\n",
        "\n",
        "# Plot all maps + rendered result\n",
        "n_maps = len(tex_maps) + 2  # +input +rendered\n",
        "cols = min(6, n_maps)\n",
        "rows = (n_maps + cols - 1) // cols\n",
        "fig, axes = plt.subplots(rows, cols, figsize=(cols * 3, rows * 3))\n",
        "axes = np.array(axes).flatten() if rows > 1 else ([axes] if n_maps == 1 else axes.flatten() if hasattr(axes, 'flatten') else [axes])\n",
        "\n",
        "idx = 0\n",
        "\n",
        "# Input RGB\n",
        "axes[idx].imshow(sample[0][:3].permute(1,2,0).cpu().clamp(0,1))\n",
        "axes[idx].set_title(\"Input RGB\", fontsize=9)\n",
        "axes[idx].axis('off')\n",
        "idx += 1\n",
        "\n",
        "# Rendered sphere\n",
        "axes[idx].imshow(rendered[0].permute(1,2,0).cpu().clamp(0,1))\n",
        "axes[idx].set_title(\"Rendered\", fontsize=9)\n",
        "axes[idx].axis('off')\n",
        "idx += 1\n",
        "\n",
        "# Each texture map\n",
        "for name, tex in tex_maps.items():\n",
        "    if idx >= len(axes):\n",
        "        break\n",
        "    img = tex[0].permute(1,2,0).cpu().clamp(0,1)\n",
        "    if img.shape[-1] == 1:\n",
        "        axes[idx].imshow(img.squeeze(-1), cmap='gray', vmin=0, vmax=1)\n",
        "    else:\n",
        "        axes[idx].imshow(img)\n",
        "    axes[idx].set_title(name.replace('_', ' ').title(), fontsize=9)\n",
        "    axes[idx].axis('off')\n",
        "    idx += 1\n",
        "\n",
        "# Hide unused axes\n",
        "for j in range(idx, len(axes)):\n",
        "    axes[j].axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "311f2fa4"
      },
      "source": [
        "### 10. Local Image Preprocessing\n",
        "Handles loading a standard image file (JPG/PNG), resizing, and padding to match the model's 7-channel input."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 48,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "2414f066",
        "outputId": "1fdaf275-b517-427a-d5a4-c7d953c9d67c"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Preprocessing and inference functions defined.\n"
          ]
        }
      ],
      "source": [
        "def preprocess_local_image(image_path, target_size=(128, 128)):\n",
        "    \"\"\"\n",
        "    Load a local image and prepare it for PBRNet inference.\n",
        "    Pads RGB to 7 channels if the model expects it.\n",
        "    \"\"\"\n",
        "    img = Image.open(image_path).convert('RGB')\n",
        "    transform = T.Compose([T.Resize(target_size), T.ToTensor()])\n",
        "    img_tensor = transform(img).unsqueeze(0).to(device)  # [1, 3, H, W]\n",
        "\n",
        "    if model.encoder[0].in_channels == 7:\n",
        "        padding = torch.zeros((1, 4, target_size[0], target_size[1]), device=device)\n",
        "        img_tensor = torch.cat([img_tensor, padding], dim=1)\n",
        "\n",
        "    return img_tensor\n",
        "\n",
        "def predict_pbr(image_tensor):\n",
        "    \"\"\"Run inference and visualize all predicted PBR maps + rendered result.\"\"\"\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        pbr_out = model(image_tensor)\n",
        "        rendered = render_pbr_sphere(pbr_out, size=128)\n",
        "\n",
        "        # Print scalar values\n",
        "        print(\"=\" * 50)\n",
        "        print(\"Predicted PBR Parameters:\")\n",
        "        print(\"=\" * 50)\n",
        "        for name, val in pbr_out.items():\n",
        "            if val.dim() == 2:\n",
        "                print(f\"  {name}: {val[0].item():.4f}\")\n",
        "            else:\n",
        "                print(f\"  {name}: texture map {list(val.shape[1:])}\")\n",
        "\n",
        "        # Collect texture maps\n",
        "        tex_maps = {k: v for k, v in pbr_out.items() if v.dim() == 4}\n",
        "        n_plots = len(tex_maps) + 2  # +input +rendered\n",
        "        cols = min(6, n_plots)\n",
        "        rows = (n_plots + cols - 1) // cols\n",
        "        fig, axes = plt.subplots(rows, cols, figsize=(cols * 3, rows * 3))\n",
        "        if rows == 1 and cols == 1:\n",
        "            axes = np.array([axes])\n",
        "        axes = np.array(axes).flatten()\n",
        "\n",
        "        idx = 0\n",
        "        # Input\n",
        "        axes[idx].imshow(image_tensor[0][:3].permute(1,2,0).cpu().clamp(0,1))\n",
        "        axes[idx].set_title(\"Input\", fontsize=9)\n",
        "        axes[idx].axis('off')\n",
        "        idx += 1\n",
        "\n",
        "        # Rendered\n",
        "        axes[idx].imshow(rendered[0].permute(1,2,0).cpu().clamp(0,1))\n",
        "        axes[idx].set_title(\"Rendered (PBR)\", fontsize=9)\n",
        "        axes[idx].axis('off')\n",
        "        idx += 1\n",
        "\n",
        "        # Each texture map\n",
        "        for name, tex in tex_maps.items():\n",
        "            if idx >= len(axes): break\n",
        "            img = tex[0].permute(1,2,0).cpu().clamp(0,1)\n",
        "            if img.shape[-1] == 1:\n",
        "                axes[idx].imshow(img.squeeze(-1), cmap='gray', vmin=0, vmax=1)\n",
        "            else:\n",
        "                axes[idx].imshow(img)\n",
        "            axes[idx].set_title(name.replace('_', ' ').title(), fontsize=9)\n",
        "            axes[idx].axis('off')\n",
        "            idx += 1\n",
        "\n",
        "        for j in range(idx, len(axes)):\n",
        "            axes[j].axis('off')\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "\n",
        "    return pbr_out\n",
        "\n",
        "print(\"Preprocessing and inference functions defined.\")"
      ]
    },
