      "source": [
        "class ResBlock(nn.Module):\n",
        "    \"\"\"Residual block with two convolutions.\"\"\"\n",
        "    def __init__(self, channels):\n",
        "        super().__init__()\n",
        "        self.block = nn.Sequential(\n",
        "            nn.Conv2d(channels, channels, 3, padding=1),\n",
        "            nn.BatchNorm2d(channels),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.Conv2d(channels, channels, 3, padding=1),\n",
        "            nn.BatchNorm2d(channels),\n",
        "        )\n",
        "    def forward(self, x):\n",
        "        return F.relu(x + self.block(x))\n",
        "\n",
        "\n",
        "class TextureDecoder(nn.Module):\n",
        "    \"\"\"Decodes a latent vector into a texture map of given channels.\n",
        "    Built dynamically from NETWORK_CONFIG['decoder_channels'].\"\"\"\n",
        "    def __init__(self, latent_dim, out_channels, decoder_channels=None, out_size=128):\n",
        "        super().__init__()\n",
        "        self.out_size = out_size\n",
        "        if decoder_channels is None:\n",
        "            decoder_channels = [256, 128, 64, 32, 16]\n",
        "\n",
        "        first_ch = decoder_channels[0]\n",
        "        self.fc = nn.Linear(latent_dim, first_ch * 4 * 4)\n",
        "        self.first_ch = first_ch\n",
        "\n",
        "        layers = []\n",
        "        in_ch = first_ch\n",
        "        for out_ch in decoder_channels[1:]:\n",
        "            layers.append(ResBlock(in_ch))\n",
        "            layers.append(nn.Upsample(scale_factor=2))\n",
        "            layers.append(nn.Conv2d(in_ch, out_ch, 3, padding=1))\n",
        "            layers.append(nn.BatchNorm2d(out_ch))\n",
        "            layers.append(nn.ReLU(True))\n",
        "            in_ch = out_ch\n",
        "        # Final upsample + output conv\n",
        "        layers.append(nn.Upsample(scale_factor=2))\n",
        "        layers.append(nn.Conv2d(in_ch, out_channels, 3, padding=1))\n",
        "        self.decoder = nn.Sequential(*layers)\n",
        "\n",
        "    def forward(self, z):\n",
        "        x = self.fc(z).view(-1, self.first_ch, 4, 4)\n",
        "        x = self.decoder(x)\n",
        "        return torch.sigmoid(x)\n",
        "\n",
        "\n",
        "def build_encoder(in_channels, encoder_layers):\n",
        "    \"\"\"Build encoder dynamically from NETWORK_CONFIG['encoder_layers'].\"\"\"\n",
        "    layers = []\n",
        "    prev_ch = in_channels\n",
        "    for layer_cfg in encoder_layers:\n",
        "        out_ch = layer_cfg[\"out_channels\"]\n",
        "        layers.append(nn.Conv2d(prev_ch, out_ch, 4, stride=2, padding=1))\n",
        "        layers.append(nn.BatchNorm2d(out_ch))\n",
        "        layers.append(nn.ReLU(True))\n",
        "        if layer_cfg.get(\"resblock\", False):\n",
        "            layers.append(ResBlock(out_ch))\n",
        "        prev_ch = out_ch\n",
        "    layers.append(nn.AdaptiveAvgPool2d(1))\n",
        "    layers.append(nn.Flatten())\n",
        "    return nn.Sequential(*layers), prev_ch\n",
        "\n",
        "\n",
        "class PBRNet(nn.Module):\n",
        "    \"\"\"\n",
        "    Full PBR material prediction network.\n",
        "    Architecture is driven by NETWORK_CONFIG:\n",
        "      - Encoder layers/neurons from encoder_layers\n",
        "      - Texture decoders from decoder_channels + latent_dim\n",
        "      - Scalar head from enabled scalar params\n",
        "    \"\"\"\n",
        "    def __init__(self, in_channels=7, network_config=None, pbr_config=None):\n",
        "        super().__init__()\n",
        "        self.pbr_cfg = pbr_config or get_enabled_params()\n",
        "        net_cfg = network_config or NETWORK_CONFIG\n",
        "\n",
        "        latent_dim = net_cfg[\"latent_dim\"]\n",
        "        self.latent_dim = latent_dim\n",
        "        decoder_channels = net_cfg.get(\"decoder_channels\", [256, 128, 64, 32, 16])\n",
        "\n",
        "        # --- Encoder (configurable) ---\n",
        "        self.encoder, enc_out_dim = build_encoder(in_channels, net_cfg[\"encoder_layers\"])\n",
        "\n",
        "        # --- Texture map heads ---\n",
        "        self.texture_latent_heads = nn.ModuleDict()\n",
        "        self.texture_decoders = nn.ModuleDict()\n",
        "\n",
        "        for name, cfg in self.pbr_cfg.items():\n",
        "            if cfg[\"type\"] != \"scalar\":\n",
        "                self.texture_latent_heads[name] = nn.Sequential(\n",
        "                    nn.Linear(enc_out_dim, latent_dim),\n",
        "                    nn.ReLU(True),\n",
        "                )\n",
        "                self.texture_decoders[name] = TextureDecoder(\n",
        "                    latent_dim, cfg[\"channels\"],\n",
        "                    decoder_channels=decoder_channels, out_size=128\n",
        "                )\n",
        "\n",
        "        # --- Scalar head ---\n",
        "        scalar_names = [n for n, c in self.pbr_cfg.items() if c[\"type\"] == \"scalar\"]\n",
        "        self.scalar_names = scalar_names\n",
        "        if scalar_names:\n",
        "            self.scalar_head = nn.Sequential(\n",
        "                nn.Linear(enc_out_dim, 128),\n",
        "                nn.ReLU(True),\n",
        "                nn.Linear(128, len(scalar_names)),\n",
        "                nn.Sigmoid(),\n",
        "            )\n",
        "\n",
        "    def forward(self, x):\n",
        "        features = self.encoder(x)\n",
        "\n",
        "        outputs = {}\n",
        "\n",
        "        # Decode texture maps\n",
        "        for name in self.texture_latent_heads:\n",
        "            latent = self.texture_latent_heads[name](features)\n",
        "            outputs[name] = self.texture_decoders[name](latent)\n",
        "\n",
        "        # Predict scalars\n",
        "        if self.scalar_names:\n",
        "            scalars = self.scalar_head(features)\n",
        "            for i, name in enumerate(self.scalar_names):\n",
        "                outputs[name] = scalars[:, i:i+1]\n",
        "\n",
        "        return outputs\n",
        "\n",
        "# Test instantiation with current config\n",
        "_test_model = PBRNet(in_channels=7, network_config=NETWORK_CONFIG, pbr_config=get_enabled_params()).to(device)\n",
        "_test_input = torch.randn(2, 7, 128, 128).to(device)\n",
        "_test_out = _test_model(_test_input)\n",
        "print(\"PBRNet output shapes (from NETWORK_CONFIG):\")\n",
        "for k, v in _test_out.items():\n",
        "    print(f\"  {k}: {v.shape}\")\n",
        "_param_count = sum(p.numel() for p in _test_model.parameters() if p.requires_grad)\n",
        "print(f\"Total parameters: {_param_count:,}\")\n",
        "del _test_model, _test_input, _test_out\n",
        "torch.cuda.empty_cache() if torch.cuda.is_available() else None"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "ACJy5j8MCfVZ"
      },
      "source": [
        "## 5. Cook-Torrance PBR Renderer\n",
        "\n",
        "Full physically-based renderer with:\n",
        "- **GGX/Trowbridge-Reitz** normal distribution function\n",
        "- **Smith-GGX** geometry function\n",
        "- **Schlick Fresnel** approximation\n",
        "- **Direct light** (configurable direction, color, intensity)\n",
        "- **HDR environment** (procedural sky dome with ground bounce)\n",
        "- **Emissive**, **AO**, **opacity** integration\n",
        "- All operations differentiable for backpropagation"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 53,
      "metadata": {
        "id": "XPNPn2pyCgbh"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Cook-Torrance PBR renderer defined.\n"
          ]
        }
      ],
      "source": [
        "def generate_sphere_geometry(size=128):\n",
        "    \"\"\"Generate sphere normals and mask on a grid.\"\"\"\n",
        "    x = torch.linspace(-1, 1, size)\n",
        "    y = torch.linspace(-1, 1, size)\n",
        "    xx, yy = torch.meshgrid(x, y, indexing='ij')\n",
        "    r_sq = xx**2 + yy**2\n",
        "    mask = (r_sq < 1.0).float()\n",
        "    zz = torch.sqrt(torch.clamp(1.0 - r_sq, min=1e-8)) * mask\n",
        "    normals = torch.stack([xx, yy, zz], dim=-1)  # [H, W, 3]\n",
        "    normals = normals / (torch.norm(normals, dim=-1, keepdim=True) + 1e-8)\n",
        "    return normals, mask\n",
        "\n",
        "\n",
        "def perturb_normals(base_normals, normal_map):\n",
        "    \"\"\"\n",
        "    Apply normal map perturbation in tangent space.\n",
        "    normal_map: [B, 3, H, W] in [0,1] → remap to [-1,1]\n",
        "    base_normals: [B, H, W, 3]\n",
        "    \"\"\"\n",
        "    nm = normal_map.permute(0, 2, 3, 1) * 2.0 - 1.0  # [B, H, W, 3]\n",
        "    # Simple tangent frame from base normals\n",
        "    N = base_normals\n",
        "    up = torch.tensor([0.0, 1.0, 0.0], device=N.device).expand_as(N)\n",
        "    T = torch.cross(up, N, dim=-1)\n",
        "    T = T / (torch.norm(T, dim=-1, keepdim=True) + 1e-8)\n",
        "    B = torch.cross(N, T, dim=-1)\n",
        "    # Transform normal map from tangent to world space\n",
        "    perturbed = (T * nm[..., 0:1] + B * nm[..., 1:2] + N * nm[..., 2:3])\n",
        "    return perturbed / (torch.norm(perturbed, dim=-1, keepdim=True) + 1e-8)\n",
        "\n",
        "\n",
        "def ggx_distribution(NdotH, roughness):\n",
        "    \"\"\"GGX/Trowbridge-Reitz NDF.\"\"\"\n",
        "    a = roughness * roughness\n",
        "    a2 = a * a\n",
        "    denom = NdotH * NdotH * (a2 - 1.0) + 1.0\n",
        "    return a2 / (math.pi * denom * denom + 1e-8)\n",
        "\n",
        "\n",
        "def smith_geometry(NdotV, NdotL, roughness):\n",
        "    \"\"\"Smith-GGX geometry function.\"\"\"\n",
        "    k = (roughness + 1.0) ** 2 / 8.0\n",
        "    G1_V = NdotV / (NdotV * (1.0 - k) + k + 1e-8)\n",
        "    G1_L = NdotL / (NdotL * (1.0 - k) + k + 1e-8)\n",
        "    return G1_V * G1_L\n",
        "\n",
        "\n",
        "def fresnel_schlick(cos_theta, F0):\n",
        "    \"\"\"Schlick's Fresnel approximation.\"\"\"\n",
        "    return F0 + (1.0 - F0) * torch.clamp(1.0 - cos_theta, 0.0, 1.0) ** 5\n",
        "\n",
        "\n",
        "def procedural_hdr_environment(direction, sky_intensity=1.5, ground_color=None):\n",
        "    \"\"\"\n",
        "    Simple procedural HDR environment.\n",
        "    direction: [..., 3] normalized reflection vectors\n",
        "    Returns: [..., 3] HDR color\n",
        "    \"\"\"\n",
        "    if ground_color is None:\n",
        "        ground_color = torch.tensor([0.15, 0.12, 0.10], device=direction.device)\n",
        "\n",
        "    # Sky gradient: blue at zenith, warm at horizon\n",
        "    up = direction[..., 2:3]  # z component = up\n",
        "    sky_top = torch.tensor([0.3, 0.5, 0.9], device=direction.device) * sky_intensity\n",
        "    sky_horizon = torch.tensor([0.8, 0.7, 0.6], device=direction.device) * sky_intensity\n",
        "    sky = torch.lerp(sky_horizon, sky_top, torch.clamp(up, 0.0, 1.0))\n",
        "\n",
        "    # Sun hotspot\n",
        "    sun_dir = torch.tensor([0.4, 0.3, 0.8], device=direction.device)\n",
        "    sun_dir = sun_dir / torch.norm(sun_dir)\n",
        "    sun_dot = torch.clamp((direction * sun_dir).sum(dim=-1, keepdim=True), 0.0, 1.0)\n",
        "    sun_glow = torch.pow(sun_dot, 64.0) * 5.0  # Sharp bright sun\n",
        "    sun_halo = torch.pow(sun_dot, 8.0) * 0.5   # Soft halo\n",
        "    sun_color = torch.tensor([1.0, 0.95, 0.8], device=direction.device)\n",
        "    sky = sky + (sun_glow + sun_halo) * sun_color\n",
        "\n",
        "    # Ground (below horizon)\n",
        "    ground = ground_color.expand_as(sky)\n",
        "    is_ground = (up < 0.0).float()\n",
        "    env = torch.lerp(sky, ground, is_ground)\n",
        "\n",
        "    return env\n",
        "\n",
        "\n",
        "def render_pbr_sphere(pbr_outputs, size=128,\n",
        "                      light_dir=None, light_color=None, light_intensity=3.0,\n",
        "                      env_intensity=1.0):\n",
        "    \"\"\"\n",
        "    Cook-Torrance PBR renderer on a sphere.\n",
        "\n",
        "    pbr_outputs: dict of tensors from PBRNet\n",
        "    Returns: [B, 3, H, W] rendered image\n",
        "    \"\"\"\n",
        "    # Get batch size from any available texture\n",
        "    for v in pbr_outputs.values():\n",
        "        if v.dim() == 4:\n",
        "            B = v.shape[0]\n",
        "            break\n",
        "        elif v.dim() == 2:\n",
        "            B = v.shape[0]\n",
        "\n",
        "    # Generate sphere geometry\n",
        "    normals, mask = generate_sphere_geometry(size)\n",
        "    normals = normals.to(device).unsqueeze(0).expand(B, -1, -1, -1)  # [B,H,W,3]\n",
        "    mask = mask.to(device).unsqueeze(0).expand(B, -1, -1)  # [B,H,W]\n",
        "\n",
        "    # --- Extract PBR maps (with defaults) ---\n",
        "    def get_tex(name, default_val, channels=3):\n",
        "        if name in pbr_outputs and pbr_outputs[name].dim() == 4:\n",
        "            t = pbr_outputs[name]\n",
        "            return F.interpolate(t, size=(size, size), mode='bilinear', align_corners=False).permute(0,2,3,1)\n",
        "        val = default_val if isinstance(default_val, list) else [default_val] * channels\n",
        "        return torch.tensor(val, device=device).view(1,1,1,channels).expand(B, size, size, channels)\n",
        "\n",
        "    def get_scalar(name, default_val):\n",
        "        if name in pbr_outputs:\n",
        "            s = pbr_outputs[name]\n",
        "            if s.dim() == 2:\n",
        "                return s[:, 0].view(B, 1, 1, 1).expand(B, size, size, 1)\n",
        "            return s.view(B, 1, 1, 1).expand(B, size, size, 1)\n",
        "        return torch.full((B, size, size, 1), default_val, device=device)\n",
        "\n",
        "    albedo     = get_tex(\"base_color\", [0.5, 0.5, 0.5], 3)\n",
        "    metallic   = get_tex(\"metallic\", 0.0, 1)\n",
        "    roughness  = get_tex(\"roughness\", 0.5, 1)\n",
        "    ao         = get_tex(\"ao\", 1.0, 1)\n",
        "    emissive   = get_tex(\"emissive\", [0.0, 0.0, 0.0], 3)\n",
        "    opacity    = get_tex(\"opacity\", 1.0, 1)\n",
        "    height_map = get_tex(\"height\", 0.5, 1)\n",
        "\n",
        "    # Apply normal map if available\n",
        "    N = normals\n",
        "    if \"normal_map\" in pbr_outputs and pbr_outputs[\"normal_map\"].dim() == 4:\n",
        "        nm = F.interpolate(pbr_outputs[\"normal_map\"], size=(size, size),\n",
        "                          mode='bilinear', align_corners=False)\n",
        "        N = perturb_normals(normals, nm)\n",
        "\n",
        "    # Clamp roughness to avoid division issues\n",
        "    roughness = torch.clamp(roughness, 0.04, 1.0)\n",
        "\n",
        "    # --- Lighting setup ---\n",
        "    if light_dir is None:\n",
        "        light_dir = torch.tensor([0.5, 0.3, 0.8], device=device)\n",
        "    else:\n",
        "        light_dir = torch.tensor(light_dir, device=device, dtype=torch.float32)\n",
        "    L = (light_dir / torch.norm(light_dir)).view(1, 1, 1, 3)\n",
        "\n",
        "    if light_color is None:\n",
        "        light_color = torch.tensor([1.0, 0.95, 0.9], device=device)\n",
        "    else:\n",
        "        light_color = torch.tensor(light_color, device=device, dtype=torch.float32)\n",
        "    light_col = light_color.view(1, 1, 1, 3) * light_intensity\n",
        "\n",
        "    # View direction (camera at z=+inf, so V = [0,0,1])\n",
        "    V = torch.tensor([0.0, 0.0, 1.0], device=device).view(1, 1, 1, 3)\n",
        "    H = F.normalize(L + V, dim=-1)\n",
        "\n",
        "    NdotL = torch.clamp((N * L).sum(-1, keepdim=True), 0.0, 1.0)\n",
        "    NdotV = torch.clamp((N * V).sum(-1, keepdim=True), 0.0, 1.0)\n",
        "    NdotH = torch.clamp((N * H).sum(-1, keepdim=True), 0.0, 1.0)\n",
        "    VdotH = torch.clamp((V * H).sum(-1, keepdim=True), 0.0, 1.0)\n",
        "\n",
        "    # --- Cook-Torrance BRDF ---\n",
        "    # F0: reflectance at normal incidence\n",
        "    F0_dielectric = torch.tensor([0.04, 0.04, 0.04], device=device).view(1,1,1,3)\n",
        "    F0 = torch.lerp(F0_dielectric, albedo, metallic)\n",
        "\n",
        "    D = ggx_distribution(NdotH, roughness)       # Distribution\n",
        "    G = smith_geometry(NdotV, NdotL, roughness)   # Geometry\n",
        "    Fr = fresnel_schlick(VdotH, F0)                # Fresnel\n",
        "\n",
        "    specular_brdf = (D * G * Fr) / (4.0 * NdotV * NdotL + 1e-4)\n",
        "    kD = (1.0 - Fr) * (1.0 - metallic)\n",
        "    diffuse_brdf = kD * albedo / math.pi\n",
        "\n",
        "    # Direct light contribution\n",
        "    direct = (diffuse_brdf + specular_brdf) * light_col * NdotL\n",
        "\n",
        "    # --- Environment lighting (IBL approximation) ---\n",
        "    R = 2.0 * NdotV * N - V  # Reflection vector\n",
        "    R = F.normalize(R, dim=-1)\n",
        "    env_color = procedural_hdr_environment(R) * env_intensity\n",
        "\n",
        "    # Rough surfaces see blurred env → reduce env contribution with roughness\n",
        "    env_weight = (1.0 - roughness) * 0.6 + 0.1\n",
        "    env_specular = env_color * Fr * env_weight\n",
        "    env_diffuse = procedural_hdr_environment(N) * env_intensity * kD * albedo * 0.3\n",
        "\n",
        "    # --- Combine ---\n",
        "    color = direct + env_specular + env_diffuse\n",
        "    color = color + emissive  # Add emissive glow\n",
        "    color = color * ao        # Apply ambient occlusion\n",
        "\n",
        "    # Simple tonemap (Reinhard)\n",
        "    color = color / (color + 1.0)\n",
        "\n",
        "    # Apply opacity and sphere mask\n",
        "    mask_3 = mask.unsqueeze(-1).expand_as(color)\n",
        "    bg_color = torch.tensor([0.18, 0.18, 0.22], device=device).view(1,1,1,3)\n",
        "    color = color * mask_3 * opacity + bg_color * (1.0 - mask_3 * opacity)\n",
        "\n",
        "    return color.permute(0, 3, 1, 2)  # [B, 3, H, W]\n",
        "\n",
        "print(\"Cook-Torrance PBR renderer defined.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "J2i8R_58Chlh"
      },
      "source": [
        "## 6. Training Setup\n",
        "\n",
        "Multi-objective loss:\n",
        "- **Supervised loss**: MSE between predicted texture maps and available ground truth channels\n",
        "- **Rendering loss**: MSE between rendered output and input RGB (self-supervised through differentiable rendering)\n",
        "- **Perceptual smoothness**: TV loss on texture maps for coherence"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 54,
      "metadata": {
        "id": "KizZSKs3ClLi"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Model parameters: 31,088,365\n",
            "Encoder: 5 layers → 512-dim\n",
            "Latent dim: 256\n",
            "Enabled outputs: ['base_color', 'metallic', 'roughness', 'specular', 'normal_map', 'ao', 'height']\n"
          ]
        }
      ],
      "source": [
        "model = PBRNet(in_channels=7, network_config=NETWORK_CONFIG, pbr_config=get_enabled_params()).to(device)\n",
        "optimizer = optim.Adam(model.parameters(), lr=5e-4, weight_decay=1e-5)\n",
        "scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=20, eta_min=1e-6)\n",
        "\n",
        "mse_loss = nn.MSELoss()\n",
        "l1_loss = nn.L1Loss()\n",
        "\n",
        "def total_variation_loss(x):\n",
        "    \"\"\"TV loss for spatial smoothness of texture maps.\"\"\"\n",
        "    return (torch.abs(x[:, :, 1:, :] - x[:, :, :-1, :]).mean() +\n",
        "            torch.abs(x[:, :, :, 1:] - x[:, :, :, :-1]).mean())\n",
        "\n",
        "param_count = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
        "print(f\"Model parameters: {param_count:,}\")\n",
        "print(f\"Encoder: {len(NETWORK_CONFIG['encoder_layers'])} layers → {NETWORK_CONFIG['encoder_layers'][-1]['out_channels']}-dim\")\n",
        "print(f\"Latent dim: {NETWORK_CONFIG['latent_dim']}\")\n",
        "print(f\"Enabled outputs: {list(get_enabled_params().keys())}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "ERqFlEFgCmja"
      },
      "source": [
        "7. Training Loop"
      ]
    },
    {
      "cell_type": "code",
